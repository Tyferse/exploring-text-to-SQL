{
  "name": "syntax_corr_turns",
  "description": "Tests influence of correction steps.",
  "params_config": "correction_params.json",
  "flow_config": "correction_flow.json",
  "checkpoint_after_stage": "simple_generation",
  "scan_config": {
    "correction": {
      "simple_correction": {
        "max_turns": {
          "type": "range",
          "values": [1, 9, 2]
        }
      }
    }
  },
  "flow_override": [
    {
      "module": "dbc_retrieval",
      "enabled": false
    },
    {
      "module": "correction",
      "enabled": true,
      "stages": [
        {
          "stage": "simple_correction", 
          "enabled": true
        },
        {
          "stage": "simple_semantic_correction", 
          "enabled": false
        }
      ]
    }
  ]
}