{
  "general": {
    "input_data_root": "Spider2/spider2-lite",
    "run_name": "default",
    "data_root": "data",
    "storage_root": "storage",
    "logs_root": "logs",
    "runs_root": "logs/runs",
    "model": null,
    "prompt_dir": "config/prompts", 
