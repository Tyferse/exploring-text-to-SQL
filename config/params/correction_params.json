      "runs_root": "logs/runs",
      "data_root": "data",
      "input_data_root": "Spider2/spider2-lite",
      "schema_dir": "final_schema",
      "gen_prefix": "one_step",
      "validation_mode": "unified",
      "max_turns": 2, 
      "max_workers": 2,
      "retry_config": {
        "max_attempts": 2,
        "initial_delay": 4.0,
        "max_delay": 30.0,
        "backoff_multiplier": 2.0
      }
