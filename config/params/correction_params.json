    "simple_semantic_correction": {
      "prompt_dir": "config/prompts/correction",
      "prompt_names": {
        "classify": "semantic_classify",
        "validation": "semantic_validation",
        "rules": "semantic_rules_validation",
        "output": "semantic_output_validation"
