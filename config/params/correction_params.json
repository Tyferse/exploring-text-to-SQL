      "is_multidialect": true,
      "max_workers": 8,
      "force_update": false
    }
  },
  "dbc_retrieval": {
    "model": { 
      "model_name": "Qwen3.7-9B", 
      "base_url": "https://localhost:5433",
      "api_key": null,
      "temperature": 0.0
    },
    "exploratory_execution": {
      "prompt_name": "exploratory_execution",
      "max_queries": 10,
      "max_rows": 20,
      "retry_config": {
        "max_attempts": 3,
        "initial_delay": 2.0,
        "max_delay": 30.0,
        "backoff_multiplier": 2.0
      },
      "max_workers": 4
    }
  },
  "generation": {
    "model": { 
      "model_name": "Qwen3.7-9B", 
      "base_url": "https://localhost:5433",
      "api_key": null,
      "temperature": 1.0
    },
    "simple_generation": {
      "schema_dir": "final_schema",
      "prompt_name":"gen_basic",
      "n_candidates": 1,
      "prefix": "one_step",
      "retry_config": {
        "max_attempts": 3,
        "initial_delay": 2.0,
        "max_delay": 30.0,
        "backoff_multiplier": 2.0
      },
      "max_workers": 3,
      "max_schema_tokens": 64000,
      "chars_per_token": 3.0
    }
  },
  "correction": {
    "model": { 
      "model_name": "Qwen3.7-9B", 
      "base_url": "https://localhost:5433",
      "api_key": null,
      "temperature": 0.2
    },
    "simple_correction": {
      "prompt_dir": "config/prompts/correction",
      "prompt_names": {
        "system": "syntax_system", 
        "user": "syntax_user", 
        "null": null, 
        "antiretry": null
      },
      "runs_root": "logs/runs",
      "schema_dir": "final_schema",
      "gen_prefix": "one_step",
      "max_messages": 5,
      "max_turns": 3,
      "max_workers": 2,
      "retry_config": {
        "max_attempts": 2,
        "initial_delay": 4.0,
        "max_delay": 30.0,
        "backoff_multiplier": 2.0
